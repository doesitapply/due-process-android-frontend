# DueProcess backend base URL.
# Android emulator talking to the local web backend should use 10.0.2.2.
DUEPROCESS_API_BASE_URL=http://10.0.2.2:3014/api/mobile/v1/

# Local/dev mobile auth key. In production this must match MOBILE_AUTH_ACCESS_KEY on the backend.
DUEPROCESS_MOBILE_ACCESS_KEY=__NONE__

# Firebase Authentication / Google Sign-In.
# Retrieve this from your Google Cloud Console / Firebase Console.
GOOGLE_WEB_CLIENT_ID=DEFAULT_WEB_CLIENT_ID
