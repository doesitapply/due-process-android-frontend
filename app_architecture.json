  "nonNegotiables": [
    "Android never connects directly to the database.",
    "All uploads use signed URLs.",
    "All private evidence stays behind authenticated backend services.",
    "Every finding links back to source anchors.",
    "Every direct quote gets exact-match verification.",
    "Blocked or low-confidence findings are excluded from reports by default.",
    "Offline capture must preserve local files until sync succeeds."
  ]
}
