  "mustHaveDataModels": [
    "UserSession",
    "Case",
    "Document",
    "UploadJob",
    "AgentRun",
    "Agent",
    "Finding",
    "SourceAnchor",
    "FindingAudit",
    "GeneratedReport",
    "Entitlement",
    "SyncMutation",
    "ApiError"
